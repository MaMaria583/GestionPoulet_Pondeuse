# Modèle de configuration — CE fichier est versionné, il ne doit
# contenir QUE des valeurs factices. Copiez-le en .env.local et
# remplissez-y les vraies valeurs.
#
#   cp .env.example .env.local

# Chaîne de connexion Neon (Dashboard → Connection string → Pooled)
DATABASE_URL="postgresql://UTILISATEUR:MOT_DE_PASSE@HOTE.neon.tech/BASE?sslmode=require&channel_binding=require"

# Secret de session — générer avec : openssl rand -base64 32
AUTH_SECRET="valeur-aleatoire-de-32-octets-minimum"
