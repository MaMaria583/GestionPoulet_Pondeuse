{
  "name": "gestion-poulet-pondeuse",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:push": "node --env-file=.env.local scripts/db-push.mjs",
    "db:reset": "node --env-file=.env.local scripts/db-reset.mjs",
    "db:seed": "node --env-file=.env.local scripts/db-seed.mjs",
    "db:verify": "node --env-file=.env.local scripts/db-verify.mjs",
    "db:pull": "node --env-file=.env.local ./node_modules/drizzle-kit/bin.cjs pull",
    "db:studio": "node --env-file=.env.local ./node_modules/drizzle-kit/bin.cjs studio",
    "test": "vitest run",
    "test:routes": "node --env-file=.env.local scripts/test-routes.mjs",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.3",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
